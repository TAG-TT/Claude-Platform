###############################################################################
# APPLICATION
###############################################################################

APP_NAME=ai-dev-platform
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=info

###############################################################################
# OPENAI
###############################################################################

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_ORG_ID=

###############################################################################
# ANTHROPIC / CLAUDE
###############################################################################

ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-latest

###############################################################################
# DATABASE (MYSQL)
###############################################################################

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=ai_platform

###############################################################################
# REDIS
###############################################################################

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

###############################################################################
# VECTOR DATABASE
###############################################################################

VECTOR_DB_PROVIDER=chroma
VECTOR_DB_PATH=./data/vector

###############################################################################
# AGENTS
###############################################################################

AGENT_WORKERS=4
AGENT_MEMORY_LIMIT=2048

###############################################################################
# DOCKER
###############################################################################

DOCKER_PROJECT_NAME=ai-dev-platform

###############################################################################
# TERRAFORM
###############################################################################

TF_STATE_BUCKET=
TF_REGION=us-east-1
TF_PROJECT=ai-dev-platform

###############################################################################
# SECURITY
###############################################################################

JWT_SECRET=
ENCRYPTION_KEY=

###############################################################################
# DEVELOPMENT
###############################################################################

DEBUG=true
AUTO_RELOAD=true